# Convex - get these by running `npx convex dev` once and they'll be set in
# .env.local automatically. Copy them here for new deployments.
CONVEX_DEPLOYMENT=
NEXT_PUBLIC_CONVEX_URL=
NEXT_PUBLIC_CONVEX_SITE_URL=

# Set in Convex via `npx convex env set OPENAI_API_KEY <key>`. The key is
# only used by Convex actions (analysis, briefing, treaty embeddings).
# It does NOT need to be in .env.local for the Next.js app.
